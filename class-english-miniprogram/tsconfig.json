{
    "include":  [
                    "src/**/*.ts",
                    "src/**/*.d.ts",
                    "src/**/*.vue"
                ],
    "compilerOptions":  {
                            "jsx":  "preserve",
                            "types":  [
                                          "@dcloudio/types"
                                      ],
                            "module":  "ESNext",
                            "paths":  {
                                          "@/*":  [
                                                      "./src/*"
                                                  ]
                                      },
                            "moduleResolution":  "node",
                            "isolatedModules":  true,
                            "skipLibCheck":  true,
                            "strict":  true,
                            "target":  "ESNext",
                            "resolveJsonModule":  true,
                            "noEmit":  true,
                            "esModuleInterop":  true,
                            "lib":  [
                                        "ESNext",
                                        "DOM"
                                    ]
                        }
}
