page{font-family:-apple-system,BlinkMacSystemFont,PingFang SC,Helvetica Neue,Segoe UI,Roboto,sans-serif;font-size:16px;line-height:1.5;color:#1d1d1f;background:linear-gradient(180deg,#e6f7f5,#f5f9f7 200px,#f5f5f7 400px);min-height:100vh;-webkit-font-smoothing:antialiased}view,text,image,button,input,textarea,label,navigator{box-sizing:border-box}button{margin:0;padding:0;font-family:inherit;font-size:inherit;line-height:inherit;color:inherit;background-color:transparent;border:none;border-radius:0}button:after{border:none}image{display:block;max-width:100%}::-webkit-scrollbar{width:0;height:0;background:transparent}
page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}